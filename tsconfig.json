{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"checkJs": true,
		"declaration": true,
		"declarationMap": true,
		"forceConsistentCasingInFileNames": true,
		"importHelpers": true,
		"incremental": true,
		"isolatedModules": true,
		"lib": ["ESNext"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "lib",
		"resolveJsonModule": true,
		"rootDir": ".",
		"skipLibCheck": true,
		"sourceMap": true,
		"target": "esnext",
		"types": ["node", "web"],
		"useDefineForClassFields": true
	},
	"exclude": ["./devcontainer/overlay"],
	"include": [
		"./@types",
		"./devcontainer",
		"./source",
		"./source/i18n/**/*.json",
		"./vite.config.*.js"
	]
}
