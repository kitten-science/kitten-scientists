{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"assist": {
		"actions": {
			"recommended": true,
			"source": {
				"organizeImports": "on",
				"recommended": true,
				"useSortedKeys": "off"
			}
		},
		"enabled": true
	},
	"css": {
		"assist": {
			"enabled": true
		},
		"formatter": {
			"enabled": true
		},
		"linter": {
			"enabled": true
		},
		"parser": {
			"cssModules": true
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!.venv",
			"!devcontainer/overlay",
			"!docs",
			"!lib",
			"!node_modules",
			"!output"
		]
	},
	"json": {
		"formatter": {
			"enabled": true
		}
	},
	"html": {
		"formatter": {
			"enabled": true
		},
		"linter": {
			"enabled": false
		}
	},
	"formatter": {
		"includes": ["!*.svg"]
	},
	"linter": {
		"rules": {
			"style": {
				"useArrayLiterals": "off"
			}
		}
	}
}
